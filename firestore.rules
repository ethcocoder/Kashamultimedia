rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is an admin
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Public content collections: Read only if published, Write only if admin
    match /episodes/{doc} {
      allow read: if resource.data.status == 'published';
      allow read, write: if isAdmin();
    }
    
    match /blog/{doc} {
      allow read: if resource.data.status == 'published';
      allow read, write: if isAdmin();
    }

    match /gallery/{doc} {
      allow read: if resource.data.status == 'published';
      allow read, write: if isAdmin();
    }

    match /services/{doc} {
      allow read: if resource.data.status == 'published';
      allow read, write: if isAdmin();
    }

    match /testimonials/{doc} {
      allow read: if resource.data.status == 'published';
      allow read, write: if isAdmin();
    }

    // Settings: Public read site info, admin write
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contact/Bookings: Public can create, admin can manage
    match /bookings/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    match /messages/{doc} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
